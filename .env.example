# Copy to .env and fill in. .env is gitignored.

# Required for the LLM planner. Without it, Cherion falls back to a crude
# keyword heuristic (works, but interpretations start with "Heuristic plan:").
ANTHROPIC_API_KEY=sk-ant-...

# Optional: planner model (defaults to claude-sonnet-4-6).
CHERION_MODEL=claude-sonnet-4-6
